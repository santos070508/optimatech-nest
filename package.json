{
  "name": "optimatech-smart-api",
  "version": "2.0.0",
  "description": "OptimaTech-Smart — API REST con NestJS + PostgreSQL + Arquitectura Hexagonal",
  "author": "OptimaTech-Smart",
  "private": true,
  "scripts": {
    "build":       "nest build",
    "start":       "node dist/main",
    "start:dev":   "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "lint":        "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test":        "jest",
    "test:watch":  "jest --watch",
    "test:cov":    "jest --coverage",
    "typeorm":     "typeorm-ts-node-commonjs",
    "migration:generate": "npm run typeorm -- migration:generate src/shared/infrastructure/database/migrations/$npm_config_name -d src/shared/infrastructure/database/data-source.ts",
    "migration:run":      "npm run typeorm -- migration:run -d src/shared/infrastructure/database/data-source.ts",
    "migration:revert":   "npm run typeorm -- migration:revert -d src/shared/infrastructure/database/data-source.ts"
  },
  "dependencies": {
    "@nestjs/common":      "^10.3.8",
    "@nestjs/config":      "^3.2.2",
    "@nestjs/core":        "^10.3.8",
    "@nestjs/platform-express": "^10.3.8",
    "@nestjs/swagger":     "^7.3.1",
    "@nestjs/typeorm":     "^10.0.2",
    "class-transformer":   "^0.5.1",
    "class-validator":     "^0.14.1",
    "multer":              "^1.4.5-lts.1",
    "pg":                  "^8.12.0",
    "reflect-metadata":    "^0.2.2",
    "rxjs":                "^7.8.1",
    "typeorm":             "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli":          "^10.3.2",
    "@nestjs/testing":      "^10.3.8",
    "@types/express":       "^4.17.21",
    "@types/jest":          "^29.5.12",
    "@types/multer":        "^1.4.11",
    "@types/node":          "^20.12.7",
    "@typescript-eslint/eslint-plugin": "^7.7.1",
    "@typescript-eslint/parser":        "^7.7.1",
    "eslint":               "^8.57.0",
    "jest":                 "^29.7.0",
    "ts-jest":              "^29.1.2",
    "ts-node":              "^10.9.2",
    "typescript":           "^5.4.5"
  },
  "jest": {
    "moduleFileExtensions": ["js","json","ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": { "^.+\\.(t|j)s$": "ts-jest" },
    "collectCoverageFrom": ["**/*.(t|j)s"],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
