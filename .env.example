# ── Servidor ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Base de datos PostgreSQL ─────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=optimatech_db
DB_USER=postgres
DB_PASSWORD=optima2025
DB_SYNC=false          # true solo en desarrollo inicial
DB_LOGGING=false       # true para ver queries SQL en consola

# ── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5500,http://localhost:8080

# ── Archivos ─────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

# ── Swagger ──────────────────────────────────────────────────
SWAGGER_ENABLED=true
SWAGGER_PATH=api/docs
